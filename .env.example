# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.

# ─── Database (Neon) ──────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection details
# Use the "Pooled connection" string for this. Format:
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─── Auth (Clerk) ─────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk webhook signing secret (from Webhooks tab in Clerk dashboard)
# Used to verify /api/webhooks/clerk requests
CLERK_WEBHOOK_SECRET=

# Where Clerk redirects after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── AI provider (server-side only — NEVER expose to client) ──────
# These keys are never sent to the CLI. The model name is also hidden.
NVIDIA_API_KEY=

# Optional overrides (defaults shown)
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=minimaxai/minimax-m2.7

# ─── Payments (Skydo Payment Links — option A: manual fulfillment) ──
# Create payment links at https://dashboard.skydo.com → Payment Links
# After a user pays, you manually upgrade them via /api/admin/upgrade
NEXT_PUBLIC_PAYMENT_LINK_PRO=https://dashboard.skydo.com/pay/pyl_DvhKKI
NEXT_PUBLIC_PAYMENT_LINK_PRO_PLUS=https://dashboard.skydo.com/pay/pyl_4Cfxc9

# Annual versions ($190/yr Pro, $280/yr Pro Plus — save 17% = 2 months free)
# Create separate Skydo Payment Links with these amounts and paste here.
# Until set, the annual buttons show "Coming soon".
NEXT_PUBLIC_PAYMENT_LINK_PRO_ANNUAL=
NEXT_PUBLIC_PAYMENT_LINK_PRO_PLUS_ANNUAL=

# Comma-separated Clerk user IDs allowed to call /api/admin/upgrade
# Get yours from /dashboard → Account section after sign-up
ADMIN_USER_IDS=

# ─── Stripe (kept dormant — for future migration to recurring billing) ──
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ─── App config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Beta mode ────────────────────────────────────────────────────
# When true, ALL users get Pro features free (no Stripe required)
# Set to false when you're ready to start charging
NEXT_PUBLIC_BETA_FREE=true
